@model IEnumerable<Movie>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Available Movies</h2>

        <form asp-area="Customer" asp-controller="Home" asp-action="Index" method="get" class="d-flex">
            <input type="text"
                   name="query"
                   value="@ViewBag.Query"
                   class="form-control me-2"
                   placeholder="Search movie..." />

            <button class="btn btn-dark" type="submit">
                Search
            </button>
        </form>
    </div>

    <div class="row g-4">
        @foreach (var movie in Model)
        {
            <div class="col-md-4">
                <div class="card shadow border-0 h-100 rounded-4">

                    <img src="~/Images_Layout/Admin/MovieImage/MovieMainImage/@movie.MainImg"
                         class="card-img-top rounded-top-4"
                         style="height: 320px; object-fit:contain;" />

                    <div class="card-body">
                        <h5 class="card-title">@movie.Name</h5>

                        <p class="text-muted mb-1">
                            <i class="fa fa-layer-group"></i>
                            @movie.Category.Name
                        </p>

                        @* <p class="text-muted mb-1">
                            <i class="fa fa-building"></i>
                            @movie.Cinema.Name
                        </p> *@
                        @* @foreach(var item in movie.ShowTimes)
                        {
                            if(item is not null)
                            {
                                
                            <p class="fw-bold text-success">
                                @item.StartTime
                                @item.Price EGP
                            </p>                           
                            }
                            
                        } *@

                        <a asp-area="Customer"
                           asp-controller="Home"
                           asp-action="Details"
                           asp-route-id="@movie.Id"
                           class="btn btn-dark w-100">
                            View Details
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
</div>
@section Scripts{
    <partial name="_NotificationPartial" />
}