@* @using Cinema_Project.ViewModel
@model BookVM

@{
    var bookedSeatIds = Model.BookedSeatIds ?? Enumerable.Empty<int>();
    var totalSeats = Model.Seats?.Count() ?? 0;
    var bookedCount = bookedSeatIds.Count();
    var availableCount = totalSeats - bookedCount;
    var ticketPrice = Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture);
}

<section class="booking-page">
    <div class="booking-shell">
        <div class="show-header">
            <div>
                <span class="show-kicker">Now booking</span>
                <h1>@Model.MovieName</h1>

                <div class="show-meta">
                    <span>@Model.CinemaName</span>
                    <span>@Model.StartTime.ToString("dd MMM yyyy")</span>
                    <span>@Model.StartTime.ToString("hh:mm tt")</span>
                </div>
            </div>

            <div class="price-chip">
                <span>Ticket</span>
                <strong>@Model.Price EGP</strong>
            </div>
        </div>

        <form asp-action="ConfirmBooking" method="post" class="booking-layout" id="bookingForm">
            @Html.AntiForgeryToken()

            <input type="hidden" name="showTimeId" value="@Model.ShowTimeId" />

            <div class="seat-panel">
                <div class="screen-wrap" aria-hidden="true">
                    <div class="screen-glow"></div>
                    <div class="screen">SCREEN</div>
                </div>

                <div class="seat-map-wrapper">
                    <div class="aisle-note">Central Walkway</div>

                    <div class="seat-map" aria-label="Cinema seat map">
                        @foreach (var seat in Model.Seats)
                        {
                            var isBooked = bookedSeatIds.Contains(seat.Id);

                            <button type="button"
                                    class="seat @(isBooked ? "booked" : "available")"
                                    data-seat-id="@seat.Id"
                                    data-seat-number="@seat.SeatNumber"
                                    aria-label="Seat @seat.SeatNumber @(isBooked ? "booked" : "available")"
                                    aria-pressed="false"
                                    @(isBooked ? "disabled" : "")>
                                @seat.SeatNumber
                            </button>
                        }
                    </div>
                </div>

                <div class="seat-legend" aria-label="Seat legend">
                    <span><i class="legend-dot available-dot"></i> Available</span>
                    <span><i class="legend-dot booked-dot"></i> Booked</span>
                    <span><i class="legend-dot selected-dot"></i> Selected</span>
                </div>
            </div>

            <aside class="booking-summary" aria-label="Booking summary">
                <div class="summary-card">
                    <h2>Booking Summary</h2>

                    <div class="summary-line">
                        <span>Available seats</span>
                        <strong>@availableCount</strong>
                    </div>

                    <div class="summary-line">
                        <span>Booked seats</span>
                        <strong>@bookedCount</strong>
                    </div>

                    <div class="summary-line">
                        <span>Selected seats</span>
                        <strong id="selectedCount">0</strong>
                    </div>

                    <div class="selected-list" id="selectedSeatList">
                        No seats selected
                    </div>

                    <div class="total-box">
                        <span>Total</span>
                        <strong><span id="totalPrice">0</span> EGP</strong>
                    </div>

                    <button type="submit" class="confirm-btn" id="confirmButton" disabled>
                        Confirm Booking
                    </button>
                </div>
            </aside>
        </form>
    </div>
</section>

<style>
    .booking-page {
        min-height: calc(100vh - 80px);
        padding: 48px 16px;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 32rem), linear-gradient(135deg, #111827 0%, #18181b 52%, #0f172a 100%);
        color: #f8fafc;
    }

    .booking-shell {
        width: min(1180px, 100%);
        margin: 0 auto;
    }

    .show-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 28px;
    }

    .show-kicker {
        display: inline-flex;
        margin-bottom: 10px;
        color: #86efac;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .show-header h1 {
        margin: 0;
        color: #ffffff;
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 900;
        line-height: 1;
    }

    .show-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
        color: #cbd5e1;
        font-weight: 600;
    }

        .show-meta span {
            padding: 8px 12px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.06);
        }

    .price-chip {
        min-width: 150px;
        padding: 16px 18px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.08);
        text-align: right;
    }

        .price-chip span {
            display: block;
            color: #cbd5e1;
            font-size: 0.82rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .price-chip strong {
            color: #ffffff;
            font-size: 1.45rem;
        }

    .booking-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 330px;
        gap: 24px;
        align-items: start;
    }

    .seat-panel,
    .summary-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: rgba(15, 23, 42, 0.74);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
    }

    .seat-panel {
        padding: clamp(20px, 4vw, 40px);
        overflow-x: auto;
    }

    .screen-wrap {
        width: min(680px, 100%);
        margin: 0 auto 44px;
        text-align: center;
    }

    .screen-glow {
        height: 24px;
        margin: 0 auto -6px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.24);
        filter: blur(18px);
    }

    .screen {
        height: 48px;
        border-radius: 100% 100% 12px 12px;
        background: linear-gradient(180deg, #f8fafc, #94a3b8);
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        letter-spacing: 0.22em;
        box-shadow: 0 18px 42px rgba(148, 163, 184, 0.18);
    }

    .seat-map-wrapper {
        width: fit-content;
        margin: 0 auto;
    }

    .aisle-note {
        text-align: center;
        margin-bottom: 14px;
        color: #94a3b8;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .seat-map {
        display: grid;
        /*
                5 كراسي شمال
                عمود فاضي للممر
                5 كراسي يمين
            */
        grid-template-columns: repeat(5, minmax(42px, 54px)) 58px repeat(5, minmax(42px, 54px));
        column-gap: 12px;
        row-gap: 22px;
        justify-content: center;
        min-width: 700px;
        position: relative;
        padding: 14px 18px;
    }

        /* الكرسي رقم 6 في كل صف يبدأ بعد الممر */
        .seat-map .seat:nth-child(10n + 6) {
            grid-column: 7;
        }

        /* شكل الممر في النص */
        .seat-map::before {
            content: "";
            position: absolute;
            top: 14px;
            bottom: 14px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.06);
            pointer-events: none;
        }

        /* مسافة زيادة بعد كل كام صف عشان تبقى شبه السينما */
        .seat-map .seat:nth-child(n + 21):nth-child(-n + 30) {
            margin-top: 12px;
        }

        .seat-map .seat:nth-child(n + 51):nth-child(-n + 60) {
            margin-top: 12px;
        }

    .seat {
        width: 100%;
        aspect-ratio: 1 / 0.86;
        border: 0;
        border-radius: 8px 8px 14px 14px;
        color: #ffffff;
        font-size: 0.78rem;
        font-weight: 900;
        box-shadow: inset 0 -5px 0 rgba(0, 0, 0, 0.18), 0 10px 20px rgba(0, 0, 0, 0.2);
        transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease;
        position: relative;
        z-index: 1;
    }

        .seat.available {
            background: #16a34a;
            cursor: pointer;
        }

            .seat.available:hover {
                transform: translateY(-3px);
                filter: brightness(1.1);
            }

        .seat.booked {
            background: #dc2626;
            cursor: not-allowed;
            opacity: 0.8;
        }

        .seat.selected {
            background: #2563eb;
            box-shadow: inset 0 -5px 0 rgba(0, 0, 0, 0.18), 0 0 0 4px rgba(147, 197, 253, 0.22);
        }

    .seat-legend {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        margin-top: 34px;
        color: #dbeafe;
        font-weight: 700;
    }

        .seat-legend span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

    .legend-dot {
        width: 13px;
        height: 13px;
        border-radius: 999px;
        display: inline-block;
    }

    .available-dot {
        background: #16a34a;
    }

    .booked-dot {
        background: #dc2626;
    }

    .selected-dot {
        background: #2563eb;
    }

    .booking-summary {
        position: sticky;
        top: 24px;
    }

    .summary-card {
        padding: 24px;
    }

        .summary-card h2 {
            margin: 0 0 22px;
            color: #ffffff;
            font-size: 1.35rem;
            font-weight: 900;
        }

    .summary-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 13px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        color: #cbd5e1;
        font-weight: 700;
    }

        .summary-line strong {
            color: #ffffff;
        }

    .selected-list {
        min-height: 54px;
        margin: 20px 0;
        padding: 14px;
        border: 1px dashed rgba(255, 255, 255, 0.18);
        border-radius: 8px;
        color: #cbd5e1;
        font-weight: 700;
        line-height: 1.6;
    }

    .total-box {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
        padding: 18px;
        border-radius: 8px;
        background: #f8fafc;
        color: #111827;
        font-weight: 900;
    }

        .total-box strong {
            font-size: 1.35rem;
        }

    .confirm-btn {
        width: 100%;
        min-height: 52px;
        border: 0;
        border-radius: 8px;
        background: #22c55e;
        color: #052e16;
        font-size: 1rem;
        font-weight: 900;
        transition: transform 160ms ease, filter 160ms ease, opacity 160ms ease;
    }

        .confirm-btn:not(:disabled):hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

        .confirm-btn:disabled {
            cursor: not-allowed;
            opacity: 0.48;
        }

    @@media (max-width: 992px) {
        .booking-layout {
            grid-template-columns: 1fr;
        }

        .booking-summary {
            position: static;
        }

        .seat-map {
            min-width: 640px;
        }
    }

    @@media (max-width: 640px) {
        .booking-page {
            padding: 28px 12px;
        }

        .show-header {
            align-items: stretch;
            flex-direction: column;
        }

        .price-chip {
            text-align: left;
        }

        .seat-map {
            grid-template-columns: repeat(2, minmax(42px, 54px)) 38px repeat(3, minmax(42px, 54px));
            min-width: 0;
            column-gap: 10px;
            row-gap: 18px;
            padding: 8px;
        }

            .seat-map .seat:nth-child(10n + 6) {
                grid-column: auto;
            }

            .seat-map .seat:nth-child(5n + 3) {
                grid-column: 4;
            }

            .seat-map::before {
                width: 30px;
            }
    }
</style>

<script>
    (() => {
        const selectedSeats = [];
        const selectedSeatNumbers = new Map();

        const bookingForm = document.getElementById("bookingForm");
        const totalPrice = document.getElementById("totalPrice");
        const selectedCount = document.getElementById("selectedCount");
        const selectedSeatList = document.getElementById("selectedSeatList");
        const confirmButton = document.getElementById("confirmButton");

        const ticketPrice = Number("@ticketPrice");
            function renderSelectedInputs() {
        document.querySelectorAll(".selected-seat-input").forEach(input => input.remove());

        selectedSeats.forEach(seatId => {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = "selectedSeatIds";
            input.value = seatId;
            input.classList.add("selected-seat-input");

            bookingForm.appendChild(input);
        });
    }

            function renderSummary() {
        renderSelectedInputs();

        selectedCount.innerText = selectedSeats.length;
        totalPrice.innerText = (selectedSeats.length * ticketPrice).toLocaleString("en-US");
        confirmButton.disabled = selectedSeats.length === 0;

        if (selectedSeats.length === 0) {
            selectedSeatList.innerText = "No seats selected";
            return;
        }

        selectedSeatList.innerText = selectedSeats
            .map(seatId => selectedSeatNumbers.get(seatId))
            .join(", ");
    }

        document.querySelectorAll(".seat.available").forEach(seat => {
            seat.addEventListener("click", function () {
                const seatId = this.dataset.seatId;

                if (selectedSeats.includes(seatId)) {
                    selectedSeats.splice(selectedSeats.indexOf(seatId), 1);
                    selectedSeatNumbers.delete(seatId);
                    this.classList.remove("selected");
                    this.setAttribute("aria-pressed", "false");
                } else {
                    selectedSeats.push(seatId);
                    selectedSeatNumbers.set(seatId, this.dataset.seatNumber);
                    this.classList.add("selected");
                    this.setAttribute("aria-pressed", "true");
                }

                renderSummary();
            });
        });

        document.getElementById("bookingForm").addEventListener("submit", event => {
            if (selectedSeats.length === 0) {
                event.preventDefault();
            }
        });
    })();
</script>

@section Scripts {
    <partial name="_NotificationPartial" />
} *@

@using Cinema_Project.ViewModel
@model BookVM

@{
    var bookedSeatIds = Model.BookedSeatIds ?? Enumerable.Empty<int>();
    var pendingSeatIds = Model.PendingSeatIds ?? Enumerable.Empty<int>();

    var totalSeats = Model.Seats?.Count() ?? 0;
    var bookedCount = bookedSeatIds.Count();
    var pendingCount = pendingSeatIds.Count();
    var availableCount = totalSeats - bookedCount - pendingCount;

    var ticketPrice = Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture);
}

<section class="booking-page">
    <div class="booking-shell">
        <div class="show-header">
            <div>
                <span class="show-kicker">Now booking</span>
                <h1>@Model.MovieName</h1>

                <div class="show-meta">
                    <span>@Model.CinemaName</span>
                    <span>@Model.StartTime.ToString("dd MMM yyyy")</span>
                    <span>@Model.StartTime.ToString("hh:mm tt")</span>
                </div>
            </div>

            <div class="price-chip">
                <span>Ticket</span>
                <strong>@Model.Price EGP</strong>
            </div>
        </div>

        <form asp-action="ConfirmBooking" method="post" class="booking-layout" id="bookingForm">
            @Html.AntiForgeryToken()

            <input type="hidden" name="showTimeId" value="@Model.ShowTimeId" />

            <div class="seat-panel">
                <div class="screen-wrap" aria-hidden="true">
                    <div class="screen-glow"></div>
                    <div class="screen">SCREEN</div>
                </div>

                <div class="seat-map-wrapper">
                    <div class="aisle-note">Central Walkway</div>

                    <div class="seat-map" aria-label="Cinema seat map">
                        @foreach (var seat in Model.Seats)
                        {
                            var isBooked = bookedSeatIds.Contains(seat.Id);
                            var isPending = pendingSeatIds.Contains(seat.Id);

                            var seatClass = isBooked ? "booked" : isPending ? "pending" : "available";
                            var seatStatus = isBooked ? "booked" : isPending ? "pending" : "available";

                            <button type="button"
                                    class="seat @seatClass"
                                    data-seat-id="@seat.Id"
                                    data-seat-number="@seat.SeatNumber"
                                    aria-label="Seat @seat.SeatNumber @seatStatus"
                                    aria-pressed="false"
                                    @(isBooked || isPending ? "disabled" : "")>
                                @seat.SeatNumber
                            </button>
                        }
                    </div>
                </div>

                <div class="seat-legend" aria-label="Seat legend">
                    <span><i class="legend-dot available-dot"></i> Available</span>
                    <span><i class="legend-dot pending-dot"></i> Pending</span>
                    <span><i class="legend-dot booked-dot"></i> Booked</span>
                    <span><i class="legend-dot selected-dot"></i> Selected</span>
                </div>
            </div>

            <aside class="booking-summary" aria-label="Booking summary">
                <div class="summary-card">
                    <h2>Booking Summary</h2>

                    <div class="summary-line">
                        <span>Available seats</span>
                        <strong>@availableCount</strong>
                    </div>

                    <div class="summary-line">
                        <span>Pending seats</span>
                        <strong>@pendingCount</strong>
                    </div>

                    <div class="summary-line">
                        <span>Booked seats</span>
                        <strong>@bookedCount</strong>
                    </div>

                    <div class="summary-line">
                        <span>Selected seats</span>
                        <strong id="selectedCount">0</strong>
                    </div>

                    <div class="selected-list" id="selectedSeatList">
                        No seats selected
                    </div>

                    <div class="total-box">
                        <span>Total</span>
                        <strong><span id="totalPrice">0</span> EGP</strong>
                    </div>

                    <button type="submit" class="confirm-btn" id="confirmButton" disabled>
                        Confirm Booking
                    </button>
                </div>
            </aside>
        </form>
    </div>
</section>

