@using Cinema_Project.Models
@model IEnumerable<Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<section class="my-bookings-page">
    <div class="container py-5">

        <div class="page-header mb-5">
            <span class="page-kicker">My Tickets</span>
            <h1>My Bookings</h1>
            <p>Here you can view all your cinema reservations.</p>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-box">
                <div class="empty-icon">
                    <i class="fa-solid fa-ticket"></i>
                </div>

                <h2>No bookings yet</h2>
                <p>You have not booked any tickets yet.</p>

                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="main-btn">
                    Browse Movies
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var booking in Model)
                {
                    var isPaid = booking.PaymentStatus == PaymentStatus.Paid;
                    var isPending = booking.PaymentStatus == PaymentStatus.Pending && booking.BookingStatus == BookingStatus.Pending;
                    var isCancelled = booking.BookingStatus == BookingStatus.Cancelled;
                    var isFailed = booking.PaymentStatus == PaymentStatus.Failed;

                    var statusText = "Unknown";
                    var statusClass = "unknown";

                    if (isPaid && booking.BookingStatus == BookingStatus.Confirmed)
                    {
                        statusText = "Confirmed";
                        statusClass = "confirmed";
                    }
                    else if (isPending)
                    {
                        statusText = "Pending Payment";
                        statusClass = "pending";
                    }
                    else if (isCancelled)
                    {
                        statusText = "Cancelled";
                        statusClass = "cancelled";
                    }
                    else if (isFailed)
                    {
                        statusText = "Payment Failed";
                        statusClass = "failed";
                    }

                    var confirmedSeatsCount = booking.BookingSeats?.Count() ?? 0;
                    var pendingSeatsCount = booking.PendingSeats?.Count() ?? 0;
                    var totalSeats = confirmedSeatsCount > 0 ? confirmedSeatsCount : pendingSeatsCount;

                    <div class="col-lg-6">
                        <div class="booking-card @statusClass">

                            <div class="booking-card-header">
                                <div>
                                    <span class="booking-number">Booking #@booking.Id</span>
                                    <h2>@booking.ShowTime?.Movie?.Name</h2>
                                </div>

                                <span class="status-badge @statusClass">
                                    @statusText
                                </span>
                            </div>

                            <div class="booking-info">

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-film"></i>
                                    </div>
                                    <div>
                                        <small>Movie</small>
                                        <strong>@booking.ShowTime?.Movie?.Name</strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-building"></i>
                                    </div>
                                    <div>
                                        <small>Cinema</small>
                                        <strong>@booking.ShowTime?.Cinema?.Name</strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-calendar-days"></i>
                                    </div>
                                    <div>
                                        <small>Date</small>
                                        <strong>@booking.ShowTime?.StartTime.ToString("dd MMM yyyy")</strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-clock"></i>
                                    </div>
                                    <div>
                                        <small>Time</small>
                                        <strong>@booking.ShowTime?.StartTime.ToString("hh:mm tt")</strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-money-bill-wave"></i>
                                    </div>
                                    <div>
                                        <small>Total Price</small>
                                        <strong>@booking.TotalPrice EGP</strong>
                                    </div>
                                </div>

                                <div class="info-item">
                                    <div class="info-icon">
                                        <i class="fa-solid fa-credit-card"></i>
                                    </div>
                                    <div>
                                        <small>Payment</small>
                                        <strong>@booking.PaymentStatus</strong>
                                    </div>
                                </div>

                            </div>

                            <div class="seats-box">
                                <small>
                                    @(isPending ? "Pending Seats" : "Selected Seats")
                                </small>

                                <div class="seats-list @(isPending ? "pending-seats" : "confirmed-seats")">
                                    @if (booking.BookingSeats != null && booking.BookingSeats.Any())
                                    {
                                        foreach (var bookingSeat in booking.BookingSeats)
                                        {
                                            <span>
                                                @(bookingSeat.Seat != null ? bookingSeat.Seat.SeatNumber : $"Seat #{bookingSeat.SeatId}")
                                            </span>
                                        }
                                    }
                                    else if (booking.PendingSeats != null && booking.PendingSeats.Any())
                                    {
                                        foreach (var pendingSeat in booking.PendingSeats)
                                        {
                                            <span>
                                                @(pendingSeat.Seat != null ? pendingSeat.Seat.SeatNumber : $"Seat #{pendingSeat.SeatId}")
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="no-seat">No seats</span>
                                    }
                                </div>
                            </div>

                            <div class="booking-footer">
                                <div>
                                    <small>Total Seats</small>
                                    <strong>@totalSeats</strong>
                                </div>

                                <div class="booking-actions">
                                    @if (isPending)
                                    {
                                        <a asp-area="Customer"
                                           asp-controller="Booking"
                                           asp-action="Pay"
                                           asp-route-bookingId="@booking.Id"
                                           class="pay-btn">
                                            Pay Now
                                        </a>

                                        <a asp-area="Customer"
                                           asp-controller="Checkout"
                                           asp-action="Cancel"
                                           asp-route-bookingId="@booking.Id"
                                           class="cancel-btn">
                                            Cancel
                                        </a>
                                    }
                                    else if (isPaid && booking.BookingStatus == BookingStatus.Confirmed)
                                    {
                                        <a asp-area="Customer"
                                           asp-controller="Checkout"
                                           asp-action="Refund"
                                           asp-route-bookingId="@booking.Id"
                                           class="refund-btn">
                                            Refund
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="disabled-action">
                                            No actions
                                        </span>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>

<style>
    .my-bookings-page {
        min-height: calc(100vh - 80px);
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 32rem), linear-gradient(135deg, #111827 0%, #18181b 50%, #020617 100%);
        color: #f8fafc;
    }

    .page-header {
        text-align: center;
    }

    .page-kicker {
        display: inline-block;
        margin-bottom: 10px;
        color: #86efac;
        font-size: 0.8rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .page-header h1 {
        margin: 0;
        color: #ffffff;
        font-size: clamp(2.2rem, 5vw, 4rem);
        font-weight: 900;
    }

    .page-header p {
        margin-top: 12px;
        color: #cbd5e1;
        font-weight: 600;
    }

    .booking-card {
        height: 100%;
        padding: 24px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 18px;
        background: rgba(15, 23, 42, 0.78);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
        transition: transform 180ms ease, border-color 180ms ease;
    }

        .booking-card:hover {
            transform: translateY(-5px);
        }

        .booking-card.confirmed:hover {
            border-color: rgba(34, 197, 94, 0.45);
        }

        .booking-card.pending:hover {
            border-color: rgba(250, 204, 21, 0.5);
        }

        .booking-card.cancelled:hover,
        .booking-card.failed:hover {
            border-color: rgba(248, 113, 113, 0.45);
        }

    .booking-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 24px;
    }

    .booking-number {
        color: #94a3b8;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .booking-card-header h2 {
        margin: 8px 0 0;
        color: #ffffff;
        font-size: 1.5rem;
        font-weight: 900;
    }

    .status-badge {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 900;
        white-space: nowrap;
    }

        .status-badge.confirmed {
            background: rgba(34, 197, 94, 0.16);
            color: #86efac;
            border: 1px solid rgba(34, 197, 94, 0.35);
        }

        .status-badge.pending {
            background: rgba(250, 204, 21, 0.18);
            color: #fde68a;
            border: 1px solid rgba(250, 204, 21, 0.45);
        }

        .status-badge.cancelled,
        .status-badge.failed {
            background: rgba(239, 68, 68, 0.16);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.35);
        }

        .status-badge.unknown {
            background: rgba(148, 163, 184, 0.16);
            color: #cbd5e1;
            border: 1px solid rgba(148, 163, 184, 0.35);
        }

    .booking-info {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.06);
    }

    .info-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(37, 99, 235, 0.18);
        color: #93c5fd;
        flex-shrink: 0;
    }

    .info-item small,
    .seats-box small,
    .booking-footer small {
        display: block;
        margin-bottom: 4px;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .info-item strong {
        color: #ffffff;
        font-weight: 800;
    }

    .seats-box {
        margin-bottom: 20px;
        padding: 15px;
        border: 1px dashed rgba(255, 255, 255, 0.2);
        border-radius: 14px;
    }

    .seats-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

        .seats-list span {
            min-width: 42px;
            padding: 8px 10px;
            border-radius: 10px;
            color: #ffffff;
            text-align: center;
            font-size: 0.82rem;
            font-weight: 900;
            box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.16);
        }

    .confirmed-seats span {
        background: #2563eb;
    }

    .pending-seats span {
        background: #facc15;
        color: #422006;
    }

    .seats-list .no-seat {
        background: rgba(148, 163, 184, 0.18);
        color: #cbd5e1;
    }

    .booking-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-top: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

        .booking-footer strong {
            color: #86efac;
            font-size: 1.3rem;
            font-weight: 900;
        }

    .booking-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
    }

    .main-btn,
    .pay-btn,
    .refund-btn,
    .cancel-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 18px;
        border-radius: 12px;
        font-weight: 900;
        text-decoration: none;
        transition: transform 160ms ease, filter 160ms ease;
    }

    .main-btn,
    .pay-btn {
        background: #22c55e;
        color: #052e16;
    }

    .refund-btn {
        background: #3b82f6;
        color: #eff6ff;
    }

    .cancel-btn {
        background: #ef4444;
        color: #fff1f2;
    }

        .main-btn:hover,
        .pay-btn:hover,
        .refund-btn:hover,
        .cancel-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

    .main-btn:hover,
    .pay-btn:hover {
        color: #052e16;
    }

    .refund-btn:hover {
        color: #eff6ff;
    }

    .cancel-btn:hover {
        color: #fff1f2;
    }

    .disabled-action {
        display: inline-flex;
        align-items: center;
        min-height: 42px;
        padding: 0 14px;
        border-radius: 12px;
        color: #94a3b8;
        background: rgba(148, 163, 184, 0.12);
        font-weight: 800;
    }

    .empty-box {
        max-width: 560px;
        margin: 40px auto 0;
        padding: 42px 28px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 22px;
        background: rgba(15, 23, 42, 0.78);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
    }

    .empty-icon {
        width: 78px;
        height: 78px;
        margin: 0 auto 18px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(37, 99, 235, 0.18);
        color: #93c5fd;
        font-size: 2rem;
    }

    .empty-box h2 {
        color: #ffffff;
        font-weight: 900;
    }

    .empty-box p {
        color: #cbd5e1;
        font-weight: 600;
        margin-bottom: 24px;
    }

    @@media (max-width: 768px) {
        .booking-info {
            grid-template-columns: 1fr;
        }

        .booking-card-header,
        .booking-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .booking-actions {
            justify-content: stretch;
        }

        .pay-btn,
        .refund-btn,
        .cancel-btn {
            flex: 1;
        }
    }
</style>
@section Scripts {
    <partial name="_NotificationPartial" />
}