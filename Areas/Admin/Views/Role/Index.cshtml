@using Cinema_Project.Utilities
@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>

<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">All Roles</h2>

        @if (User.IsInRole(RolesName.SUPER_ADMIN))
        {
            <a href="/Admin/Role/Create/" class="btn btn-success">
                Create
            </a>
        }
    </div>

    <!-- Filter -->
    <form method="get" asp-area="Admin" asp-controller="Role" asp-action="Index">
        <div class="d-flex mb-3">
            <input type="text"
                   class="form-control me-2"
                   placeholder="Role Name"
                   name="query"
                   value="@ViewBag.Query" />

            <button type="submit" class="btn btn-dark">
                Filter
            </button>
        </div>
    </form>

    <!-- Table -->
    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Role Name</th>
                <th style="width: 250px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>

                        <td>
                            @if (User.IsInRole(RolesName.SUPER_ADMIN))
                            {
                                <a href="/Admin/Role/Update/@item.Id" class="btn btn-warning btn-sm">
                                    <i class="fa fa-edit"></i> Edit
                                </a>

                                <a href="/Admin/Role/Delete/@item.Id" class="btn btn-danger btn-sm btn-delete">
                                    <i class="fa fa-trash"></i> Delete
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No Actions Available</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-muted">
                        No Roles Found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-4">

        <!-- Previous -->
        @if (ViewBag.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   href="/Admin/Role/Index?page=@(ViewBag.CurrentPage - 1)&query=@ViewBag.Query">
                    Previous
                </a>
            </li>
        }

        <!-- Page Numbers -->
        @for (var i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (ViewBag.CurrentPage == i)
            {
                <li class="page-item active">
                    <a class="page-link"
                       href="/Admin/Role/Index?page=@i&query=@ViewBag.Query">
                        @i
                    </a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       href="/Admin/Role/Index?page=@i&query=@ViewBag.Query">
                        @i
                    </a>
                </li>
            }
        }

        <!-- Next -->
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   href="/Admin/Role/Index?page=@(ViewBag.CurrentPage + 1)&query=@ViewBag.Query">
                    Next
                </a>
            </li>
        }

    </ul>
</nav>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault();

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This role will be deleted!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });
    });
</script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_NotificationPartial" />
}
