@using Cinema_Project.Models
@model Booking

@{
    ViewData["Title"] = "Refund Completed";

    var refundedAmount = ViewData["RefundedAmount"]?.ToString() ?? $"{Model.TotalPrice - 10} EGP";
    var refundFee = ViewData["RefundFee"]?.ToString() ?? "10 EGP";
    var refundId = ViewData["RefundId"]?.ToString() ?? "N/A";
    var transactionId = Model.TransactionId ?? "N/A";
}

<section class="refund-result-page">
    <div class="refund-card">

        <div class="icon-badge">
            <i class="fa-solid fa-rotate-left"></i>
        </div>

        <span class="tag">Cinema · Refund</span>

        <h1>Refund Submitted</h1>

        <p class="subtitle">
            Your refund request has been submitted successfully.
            The refunded amount will be returned to the original payment method.
        </p>

        <div class="divider"></div>

        <div class="detail-list">
            <div class="detail-row">
                <span class="detail-label">Booking ID</span>
                <span class="detail-value highlight">#@Model.Id</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Movie</span>
                <span class="detail-value">@Model.ShowTime?.Movie?.Name</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Cinema</span>
                <span class="detail-value">@Model.ShowTime?.Cinema?.Name</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Show Time</span>
                <span class="detail-value">
                    @Model.ShowTime?.StartTime.ToString("dd MMM yyyy - hh:mm tt")
                </span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Original Total</span>
                <span class="detail-value">@Model.TotalPrice EGP</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Refund Fee</span>
                <span class="detail-value fee">@refundFee</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Refunded</span>
                <span class="detail-value highlight">@refundedAmount</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Transaction</span>
                <span class="detail-value">@transactionId</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Refund ID</span>
                <span class="detail-value">@refundId</span>
            </div>

            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value badge">Refunded</span>
            </div>
        </div>

        <div class="seats-box">
            <span class="seats-title">Released Seats</span>

            <div class="seats-list">
                @if (Model.BookingSeats != null && Model.BookingSeats.Any())
                {
                    foreach (var bookingSeat in Model.BookingSeats)
                    {
                        <span>
                            @(bookingSeat.Seat != null ? bookingSeat.Seat.SeatNumber : $"Seat #{bookingSeat.SeatId}")
                        </span>
                    }
                }
                else
                {
                    <span>No seats found</span>
                }
            </div>
        </div>

        <div class="alert-box">
            <i class="fa-solid fa-circle-info"></i>
            <p>
                A 10 EGP refund fee has been deducted. Bank processing time may vary depending on the card issuer.
            </p>
        </div>

        <div class="actions">
            <a asp-area="Customer"
               asp-controller="Booking"
               asp-action="MyBookings"
               class="btn btn-ghost">
                <i class="fa-solid fa-arrow-left"></i>
                My Bookings
            </a>

            <a asp-area="Customer"
               asp-controller="Home"
               asp-action="Index"
               class="btn btn-primary">
                Browse Movies
                <i class="fa-solid fa-film"></i>
            </a>
        </div>

        <p class="timestamp">
            Processed at @DateTime.Now.ToString("dd MMM yyyy - hh:mm tt")
        </p>
    </div>
</section>

<style>
    .refund-result-page {
        min-height: calc(100vh - 80px);
        padding: 60px 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 34rem), linear-gradient(135deg, #111827 0%, #18181b 52%, #020617 100%);
        color: #f8fafc;
        overflow: hidden;
        position: relative;
    }

        .refund-result-page::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: 0.25;
            pointer-events: none;
        }

    .refund-card {
        position: relative;
        z-index: 1;
        width: min(760px, 100%);
        padding: 42px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.86);
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
        animation: slideUp 0.45s ease both;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .refund-card::before {
        content: "";
        position: absolute;
        top: -1px;
        left: 20%;
        right: 20%;
        height: 2px;
        background: linear-gradient(90deg, transparent, #3b82f6, transparent);
    }

    .icon-badge {
        width: 78px;
        height: 78px;
        margin-bottom: 20px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.18);
        color: #93c5fd;
        border: 1px solid rgba(59, 130, 246, 0.38);
        font-size: 2rem;
        box-shadow: 0 0 45px rgba(59, 130, 246, 0.18);
    }

    .tag {
        display: inline-block;
        margin-bottom: 10px;
        padding: 4px 11px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.14);
        color: #93c5fd;
        border: 1px solid rgba(59, 130, 246, 0.3);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        color: #ffffff;
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 900;
        line-height: 1;
    }

    .subtitle {
        max-width: 620px;
        margin: 16px 0 28px;
        color: #cbd5e1;
        font-weight: 600;
        line-height: 1.7;
    }

    .divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.12);
        margin: 24px 0;
    }

    .detail-list {
        display: grid;
        gap: 12px;
        margin-bottom: 22px;
    }

    .detail-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 13px 14px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .detail-label {
        color: #94a3b8;
        font-size: 0.74rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
    }

    .detail-value {
        color: #ffffff;
        text-align: right;
        font-size: 0.88rem;
        font-weight: 800;
        word-break: break-word;
    }

        .detail-value.highlight {
            color: #86efac;
        }

        .detail-value.fee {
            color: #fca5a5;
        }

        .detail-value.badge {
            padding: 4px 10px;
            border-radius: 999px;
            color: #93c5fd;
            background: rgba(59, 130, 246, 0.16);
            border: 1px solid rgba(59, 130, 246, 0.35);
            font-size: 0.74rem;
        }

    .seats-box {
        margin: 22px 0;
        padding: 18px;
        border-radius: 18px;
        border: 1px dashed rgba(255, 255, 255, 0.2);
    }

    .seats-title {
        display: block;
        margin-bottom: 12px;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .seats-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

        .seats-list span {
            min-width: 44px;
            padding: 8px 11px;
            border-radius: 12px;
            background: #3b82f6;
            color: #eff6ff;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 900;
            box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.16);
        }

    .alert-box {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        margin-bottom: 24px;
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(250, 204, 21, 0.12);
        border: 1px solid rgba(250, 204, 21, 0.34);
    }

        .alert-box i {
            color: #fde68a;
            margin-top: 3px;
        }

        .alert-box p {
            margin: 0;
            color: #fde68a;
            font-size: 0.86rem;
            font-weight: 700;
            line-height: 1.6;
        }

    .actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn {
        flex: 1;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 14px;
        border: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 900;
        transition: transform 160ms ease, filter 160ms ease;
    }

    .btn-primary {
        background: #22c55e;
        color: #052e16;
    }

    .btn-ghost {
        background: rgba(255, 255, 255, 0.08);
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.14);
    }

        .btn-primary:hover,
        .btn-ghost:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

    .btn-primary:hover {
        color: #052e16;
    }

    .btn-ghost:hover {
        color: #ffffff;
    }

    .timestamp {
        margin: 20px 0 0;
        text-align: center;
        color: #64748b;
        font-size: 0.74rem;
        font-weight: 700;
    }

    @@media (max-width: 640px) {
        .refund-card {
            padding: 28px 20px;
        }

        .detail-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .detail-value {
            text-align: left;
        }

        .actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
        }
    }
</style>
@section Scripts {
    <partial name="_NotificationPartial" />
}