@using Cinema_Project.ViewModel
@model ValidOTPVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white text-center rounded-top-4">
                    <h3 class="mb-0">Validate OTP</h3>
                </div>

                <div class="card-body p-4">

                    <p class="text-muted text-center mb-4">
                        Enter the OTP code that was sent to your email.
                    </p>

                    <form asp-action="ValidOTP" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <!-- OTP -->
                        <div class="mb-3">
                            <label asp-for="OTP" class="form-label">
                                OTP Code
                            </label>

                            <input asp-for="OTP"
                                   class="form-control text-center"
                                   placeholder="Enter OTP"
                                   maxlength="6" />

                            <span asp-validation-for="OTP" class="text-danger"></span>
                        </div>

                        <!-- Submit -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark">
                                Verify OTP
                            </button>
                        </div>

                    </form>

                </div>

                <div class="card-footer text-center bg-light rounded-bottom-4">
                    <a asp-action="ForgetPassword" class="text-decoration-none">
                        Resend OTP
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_NotificationPartial" />
}