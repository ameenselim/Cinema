@using Cinema_Project.ViewModel
@model ForgetPasswordVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white text-center rounded-top-4">
                    <h3 class="mb-0">Forget Password</h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="ForgetPassword" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <!-- UserName Or Email -->
                        <div class="mb-3">
                            <label asp-for="UserNameOrEmail" class="form-label">
                                Username or Email
                            </label>

                            <input asp-for="UserNameOrEmail"
                                   class="form-control"
                                   placeholder="Enter username or email" />

                            <span asp-validation-for="UserNameOrEmail"
                                  class="text-danger"></span>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark">
                                Send Reset Link
                            </button>
                        </div>

                    </form>

                </div>

                <div class="card-footer text-center bg-light rounded-bottom-4">
                    <a asp-action="Login" class="text-decoration-none">
                        Back to Login
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_NotificationPartial" />
}