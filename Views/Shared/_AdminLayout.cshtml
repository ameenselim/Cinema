
@using Cinema_Project.Utilities

<!DOCTYPE html>
<html lang="en-US" dir="ltr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@ViewData["Title"] - Cinema Admin</title>

    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/img/favicons/favicon-32x32.png">

    <script src="~/assets/js/config.js"></script>
    <script src="~/vendors/simplebar/simplebar.min.js"></script>

    <link href="~/vendors/simplebar/simplebar.min.css" rel="stylesheet">
    <link href="~/assets/css/theme.min.css" rel="stylesheet" id="style-default">
    <link href="~/assets/css/user.min.css" rel="stylesheet" id="user-style-default">
    <link href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
</head>

<body>
    <main class="main" id="top">
        <div class="container" data-layout="container">

            <!-- Sidebar -->
            <nav class="navbar navbar-light navbar-vertical navbar-expand-xl">

                <div class="d-flex align-items-center">
                    <div class="toggle-icon-wrapper">
                        <button class="btn navbar-toggler-humburger-icon navbar-vertical-toggle"
                                data-bs-toggle="tooltip"
                                data-bs-placement="left"
                                title="Toggle Navigation">
                            <span class="navbar-toggle-icon">
                                <span class="toggle-line"></span>
                            </span>
                        </button>
                    </div>

                    <a class="navbar-brand" href="/Admin/showtime/index">
                        <div class="d-flex align-items-center py-3">
                            <img class="me-2"
                                 src="~/assets/img/icons/spot-illustrations/falcon.png"
                                 alt=""
                                 width="40" />

                            <span class="font-sans-serif">Cinema</span>
                        </div>
                    </a>
                </div>

                <div class="collapse navbar-collapse" id="navbarVerticalCollapse">
                    <div class="navbar-vertical-content scrollbar">

                        <ul class="navbar-nav flex-column mb-3">

                            @if (User.IsInRole(RolesName.ADMIN) || User.IsInRole(RolesName.SUPER_ADMIN))

                            {

                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/DashBoard/Index">
                                        <div class="d-flex align-items-center">
                                            <span class="nav-link-icon">
                                                <span class="fas fa-chart-pie"></span>
                                            </span>
                                            <span class="nav-link-text ps-1">Dashboard</span>
                                        </div>
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Cinema/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-building"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Cinemas</span>
                                    </div>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Category/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-list"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Categories</span>
                                    </div>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Actor/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-users"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Actors</span>
                                    </div>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Movie/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-film"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Movies</span>
                                    </div>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/ShowTime/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-clock"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Show Time</span>
                                    </div>
                                </a>
                            </li>
                            @if (User.IsInRole(RolesName.SUPER_ADMIN) || User.IsInRole(RolesName.ADMIN))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/User/Index">
                                        <div class="d-flex align-items-center">
                                            <span class="nav-link-icon">
                                                <span class="fas fa-user-shield"></span>
                                            </span>
                                            <span class="nav-link-text ps-1">Users</span>
                                        </div>
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole(RolesName.SUPER_ADMIN))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/Role/Index">
                                        <div class="d-flex align-items-center">
                                            <span class="nav-link-icon">
                                                <span class="fas fa-users-cog"></span>
                                            </span>
                                            <span class="nav-link-text ps-1">Roles</span>
                                        </div>
                                    </a>
                                </li>
                            }

                            <li class="nav-item mt-3">
                                <a class="nav-link text-primary" href="/Customer/Home/Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-home"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Customer Home</span>
                                    </div>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/Identity/Account/Logout">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon">
                                            <span class="fas fa-sign-out-alt"></span>
                                        </span>
                                        <span class="nav-link-text ps-1">Logout</span>
                                    </div>
                                </a>
                            </li>

                        </ul>

                    </div>
                </div>
            </nav>

            <!-- Content -->
            <div class="content">

                <!-- Top Navbar -->
                <nav class="navbar navbar-light navbar-glass navbar-top navbar-expand">
                    <button class="btn navbar-toggler-humburger-icon navbar-toggler me-1 me-sm-3"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarVerticalCollapse">
                        <span class="navbar-toggle-icon">
                            <span class="toggle-line"></span>
                        </span>
                    </button>

                    <a class="navbar-brand me-1 me-sm-3" href="/Admin/DashBoard/Index">
                        <div class="d-flex align-items-center">
                            <span class="font-sans-serif">Cinema Admin</span>
                        </div>
                    </a>

                    <ul class="navbar-nav navbar-nav-icons ms-auto flex-row align-items-center">
                        <li class="nav-item">
                            <span class="nav-link">
                                <i class="fas fa-user"></i>
                                @User.Identity?.Name
                            </span>
                        </li>
                    </ul>
                </nav>

                <div class="mt-3">
                    @RenderBody()
                </div>

            </div>
        </div>
    </main>

    <script src="~/vendors/jquery/jquery.min.js"></script>

    <script src="~/vendors/popper/popper.min.js"></script>
    <script src="~/vendors/bootstrap/bootstrap.min.js"></script>
    <script src="~/vendors/fontawesome/all.min.js"></script>
    <script src="~/assets/js/theme.js"></script>

    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 