@using Cinema_Project.Models
@model Booking

@{
    ViewData["Title"] = "Payment Cancelled";
}

<section class="payment-result-page cancel-page">
    <div class="result-card">

        <div class="result-icon cancel-icon">
            <i class="fa-solid fa-xmark"></i>
        </div>

        <span class="result-kicker">Payment Cancelled</span>

        <h1>Your booking was cancelled</h1>

        <p class="result-text">
            The payment was not completed. Your temporarily reserved seats have been released or will be released when the reservation time expires.
        </p>

        <div class="booking-details">
            <div class="detail-item">
                <span>Booking Number</span>
                <strong>#@Model.Id</strong>
            </div>

            <div class="detail-item">
                <span>Movie</span>
                <strong>@Model.ShowTime?.Movie?.Name</strong>
            </div>

            <div class="detail-item">
                <span>Cinema</span>
                <strong>@Model.ShowTime?.Cinema?.Name</strong>
            </div>

            <div class="detail-item">
                <span>Status</span>
                <strong>@Model.BookingStatus</strong>
            </div>

            <div class="detail-item">
                <span>Payment</span>
                <strong>@Model.PaymentStatus</strong>
            </div>

            <div class="detail-item">
                <span>Total Price</span>
                <strong>@Model.TotalPrice EGP</strong>
            </div>
        </div>

        <div class="actions">
            <a asp-area="Customer"
               asp-controller="Booking"
               asp-action="Book"
               asp-route-showTimeId="@Model.ShowTimeId"
               class="main-btn">
                Choose Seats Again
            </a>

            <a asp-area="Customer"
               asp-controller="Booking"
               asp-action="MyBookings"
               class="secondary-btn">
                My Bookings
            </a>

            <a asp-area="Customer"
               asp-controller="Home"
               asp-action="Index"
               class="secondary-btn">
                Back Home
            </a>
        </div>

    </div>
</section>

<style>
    .payment-result-page {
        min-height: calc(100vh - 80px);
        padding: 60px 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top left, rgba(239, 68, 68, 0.2), transparent 34rem), linear-gradient(135deg, #111827 0%, #18181b 52%, #020617 100%);
        color: #f8fafc;
    }

    .result-card {
        width: min(760px, 100%);
        padding: 42px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
        text-align: center;
    }

    .result-icon {
        width: 94px;
        height: 94px;
        margin: 0 auto 22px;
        border-radius: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .cancel-icon {
        background: rgba(239, 68, 68, 0.18);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.4);
        box-shadow: 0 0 45px rgba(239, 68, 68, 0.22);
    }

    .result-kicker {
        display: inline-block;
        margin-bottom: 10px;
        color: #fca5a5;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .result-card h1 {
        margin: 0;
        color: #ffffff;
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 900;
    }

    .result-text {
        max-width: 580px;
        margin: 16px auto 30px;
        color: #cbd5e1;
        font-weight: 600;
        line-height: 1.7;
    }

    .booking-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 28px;
        text-align: left;
    }

    .detail-item {
        padding: 15px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

        .detail-item span {
            display: block;
            margin-bottom: 6px;
            color: #94a3b8;
            font-size: 0.75rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .detail-item strong {
            color: #ffffff;
            font-weight: 900;
        }

    .actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
    }

    .main-btn,
    .secondary-btn {
        min-height: 48px;
        padding: 0 22px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: transform 160ms ease, filter 160ms ease;
    }

    .main-btn {
        background: #ef4444;
        color: #fff1f2;
    }

    .secondary-btn {
        background: rgba(255, 255, 255, 0.08);
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.14);
    }

        .main-btn:hover,
        .secondary-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

    .main-btn:hover {
        color: #fff1f2;
    }

    .secondary-btn:hover {
        color: #ffffff;
    }

    @@media (max-width: 700px) {
        .result-card {
            padding: 30px 20px;
        }

        .booking-details {
            grid-template-columns: 1fr;
        }

        .actions {
            flex-direction: column;
        }

        .main-btn,
        .secondary-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_NotificationPartial" />
}