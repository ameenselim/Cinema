@using Cinema_Project.Models
@model Booking

@{
    ViewData["Title"] = "Payment Success";
}

<section class="payment-result-page success-page">
    <div class="result-card">

        <div class="result-icon success-icon">
            <i class="fa-solid fa-check"></i>
        </div>

        <span class="result-kicker">Payment Completed</span>

        <h1>Your booking is confirmed!</h1>

        <p class="result-text">
            Your payment has been completed successfully and your seats are now booked.
        </p>

        <div class="booking-details">
            <div class="detail-item">
                <span>Booking Number</span>
                <strong>#@Model.Id</strong>
            </div>

            <div class="detail-item">
                <span>Movie</span>
                <strong>@Model.ShowTime?.Movie?.Name</strong>
            </div>

            <div class="detail-item">
                <span>Cinema</span>
                <strong>@Model.ShowTime?.Cinema?.Name</strong>
            </div>

            <div class="detail-item">
                <span>Date</span>
                <strong>@Model.ShowTime?.StartTime.ToString("dd MMM yyyy")</strong>
            </div>

            <div class="detail-item">
                <span>Time</span>
                <strong>@Model.ShowTime?.StartTime.ToString("hh:mm tt")</strong>
            </div>

            <div class="detail-item">
                <span>Total Price</span>
                <strong>@Model.TotalPrice EGP</strong>
            </div>
        </div>

        <div class="seats-box">
            <span class="seats-title">Booked Seats</span>

            <div class="seats-list">
                @if (Model.BookingSeats != null && Model.BookingSeats.Any())
                {
                    foreach (var bookingSeat in Model.BookingSeats)
                    {
                        <span>
                            @(bookingSeat.Seat != null ? bookingSeat.Seat.SeatNumber : $"Seat #{bookingSeat.SeatId}")
                        </span>
                    }
                }
                else
                {
                    <span>No seats found</span>
                }
            </div>
        </div>

        <div class="actions">
            <a asp-area="Customer"
               asp-controller="Booking"
               asp-action="MyBookings"
               class="main-btn">
                View My Bookings
            </a>

            <a asp-area="Customer"
               asp-controller="Home"
               asp-action="Index"
               class="secondary-btn">
                Back Home
            </a>
        </div>

    </div>
</section>

<style>
    .payment-result-page {
        min-height: calc(100vh - 80px);
        padding: 60px 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top left, rgba(34, 197, 94, 0.2), transparent 34rem), linear-gradient(135deg, #111827 0%, #18181b 52%, #020617 100%);
        color: #f8fafc;
    }

    .result-card {
        width: min(760px, 100%);
        padding: 42px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.82);
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
        text-align: center;
    }

    .result-icon {
        width: 94px;
        height: 94px;
        margin: 0 auto 22px;
        border-radius: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .success-icon {
        background: rgba(34, 197, 94, 0.18);
        color: #86efac;
        border: 1px solid rgba(34, 197, 94, 0.4);
        box-shadow: 0 0 45px rgba(34, 197, 94, 0.22);
    }

    .result-kicker {
        display: inline-block;
        margin-bottom: 10px;
        color: #86efac;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .result-card h1 {
        margin: 0;
        color: #ffffff;
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 900;
    }

    .result-text {
        max-width: 560px;
        margin: 16px auto 30px;
        color: #cbd5e1;
        font-weight: 600;
        line-height: 1.7;
    }

    .booking-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 24px;
        text-align: left;
    }

    .detail-item {
        padding: 15px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

        .detail-item span {
            display: block;
            margin-bottom: 6px;
            color: #94a3b8;
            font-size: 0.75rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .detail-item strong {
            color: #ffffff;
            font-weight: 900;
        }

    .seats-box {
        margin: 22px 0 28px;
        padding: 18px;
        border-radius: 18px;
        border: 1px dashed rgba(255, 255, 255, 0.2);
        text-align: left;
    }

    .seats-title {
        display: block;
        margin-bottom: 12px;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .seats-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

        .seats-list span {
            min-width: 44px;
            padding: 8px 11px;
            border-radius: 12px;
            background: #22c55e;
            color: #052e16;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 900;
            box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.16);
        }

    .actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
    }

    .main-btn,
    .secondary-btn {
        min-height: 48px;
        padding: 0 22px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: transform 160ms ease, filter 160ms ease;
    }

    .main-btn {
        background: #22c55e;
        color: #052e16;
    }

    .secondary-btn {
        background: rgba(255, 255, 255, 0.08);
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.14);
    }

        .main-btn:hover,
        .secondary-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

    .main-btn:hover {
        color: #052e16;
    }

    .secondary-btn:hover {
        color: #ffffff;
    }

    @@media (max-width: 700px) {
        .result-card {
            padding: 30px 20px;
        }

        .booking-details {
            grid-template-columns: 1fr;
        }

        .actions {
            flex-direction: column;
        }

        .main-btn,
        .secondary-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_NotificationPartial" />
}