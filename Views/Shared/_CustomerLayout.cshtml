
@using Cinema_Project.Utilities

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Cinema</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <!-- Toastr -->
    <link rel="stylesheet"
          href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- Custom -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f5f5f5;
        }

        .navbar {
            background-color: #111827 !important;
        }

        .navbar-brand {
            font-size: 26px;
            font-weight: bold;
            color: #fff !important;
        }

        .nav-link {
            color: #e5e7eb !important;
            transition: .3s;
        }

            .nav-link:hover {
                color: #facc15 !important;
            }

        footer {
            background: #111827;
            color: white;
            padding: 15px 0;
            margin-top: 50px;
        }

        .profile-btn {
            border-radius: 30px;
            padding: 6px 18px;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand"
               asp-area="Customer"
               asp-controller="Home"
               asp-action="Index">
                🎬 Cinema
            </a>

            <!-- Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Links -->
            <div class="collapse navbar-collapse" id="navbarContent">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    @if (User.Identity is not null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                            asp-area="Customer"
                            asp-controller="Home"
                            asp-action="Index">
                                Home
                            </a>
                        </li>
                    }

                    @* <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Customer"
                           asp-controller="Movie"
                           asp-action="Index">
                            Movies
                        </a>
                    </li> *@

                    @if (User.Identity is not null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area="Customer"
                               asp-controller="Booking"
                               asp-action="MyBookings">
                                My Bookings
                            </a>
                        </li>
                    }

                    @if (User.IsInRole(RolesName.SUPER_ADMIN)
                                        || User.IsInRole(RolesName.ADMIN)
                                        || User.IsInRole(RolesName.EMPLOYEE))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold"
                               asp-area="Admin"
                               asp-controller="ShowTime"
                               asp-action="Index">
                                Dashboard
                            </a>
                        </li>
                    }

                </ul>

                <!-- Right Side -->
                <ul class="navbar-nav ms-auto">

                    @if (User.Identity is not null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-light profile-btn"
                               asp-area="Identity"
                               asp-controller="Profile"
                               asp-action="Index">

                                <i class="fa fa-user"></i>
                                @User.Identity.Name
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-danger profile-btn"
                               asp-area="Identity"
                               asp-controller="Account"
                               asp-action="Logout">

                                <i class="fa fa-right-from-bracket"></i>
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-light profile-btn"
                               asp-area="Identity"
                               asp-controller="Account"
                               asp-action="Login">

                                <i class="fa fa-right-to-bracket"></i>
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-warning profile-btn"
                               asp-area="Identity"
                               asp-controller="Account"
                               asp-action="Register">

                                <i class="fa fa-user-plus"></i>
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <!-- Main -->
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center">
            <h6 class="mb-0">
                © 2026 Cinema Booking System - All Rights Reserved
            </h6>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
